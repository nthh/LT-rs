/target
**/__pycache__
*.pyc
.venv
*.whl
.DS_Store

# lazycogs A/B (Python 3.13 venv + ephemeral geoparquet)
.venv-lazy
data/_*.parquet

# bundled test fixtures are tracked (scene rasters + the NBR box) so the examples
# and validation run without a re-fetch; only the redundant lazycogs A/B duplicate
# and parquet scratch are ignored
data/nbr_lazycogs.npz

# figures live in images/: commit the IDL 3-way pixel chart + per-scene 3-panel maps;
# everything else there is regenerable (2-panel compares, single-pixel overlay, dist map)
images/*
!images/idl_gee_rust_pixel.png
!images/forest_idl_gee_rust.png
!images/cropland_idl_gee_rust.png
!images/arid_idl_gee_rust.png
